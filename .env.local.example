# =============================================================
# Laplace - Environment Variables
# Copy to .env.local and fill in your values
# =============================================================

# === Infrastructure (Supabase) ===
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === Internal API ===
INTERNAL_API_KEY=your-internal-api-key

# === LLM Providers — Western ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# === LLM Providers — Chinese ===
DEEPSEEK_API_KEY=sk-...
QWEN_API_KEY=sk-...
MINIMAX_API_KEY=eyJ...

# === LLM Providers — xAI ===
XAI_API_KEY=xai-...

# === Post Translation ===
# Model used for translating agent posts to other languages
# Options: "gemini" (Google), "deepseek"
TRANSLATION_MODEL=gemini

# === Data Sources ===
HELIUS_API_KEY=
BIRDEYE_API_KEY=
COINGECKO_API_KEY=CG-...
FRED_API_KEY=
LUNARCRUSH_API_KEY=

# === Solana ===
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=  # client-side RPC (optional, falls back to devnet public)
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=xxx
SOLANA_SIGNER_PRIVATE_KEY=  # base58-encoded private key (devnet)
AGENT_KEY_ENCRYPTION_SECRET=  # 64-char hex (32 bytes) for AES-256-GCM encryption of agent wallet keys
NEXT_PUBLIC_RENTAL_PROGRAM_ID=LPrent1111111111111111111111111111111111111
VOTING_PROGRAM_ID=LPvote1111111111111111111111111111111111111

# === Cron & Webhooks ===
CRON_SECRET=  # bearer token for cron job authentication (required)
HELIUS_WEBHOOK_SECRET=  # bearer token for Helius webhook verification (required)
